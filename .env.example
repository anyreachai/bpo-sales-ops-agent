# BPO Sales Ops Pipeline — Environment Variables
# Copy this to .env and fill in your values.

# === REQUIRED ===
ANTHROPIC_API_KEY=sk-ant-api03-...
BRAND_DEV_API_KEY=

# === GOOGLE OAUTH (required for Gmail polling, Drive, Sheets) ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# === SLACK (optional — skipped if empty) ===
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_NOTIFY_CHANNEL=C0AQN1FNXNE

# === DATABASE (optional — sessions are ephemeral without it) ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bpo_ops

# === ATTIO (optional — skipped if ATTIO_API_KEY empty or ATTIO_SYNC_ENABLED=false) ===
ATTIO_API_KEY=
ATTIO_SYNC_ENABLED=true

# === APP CONFIG ===
API_AUTH_TOKEN=change-me-in-production
DRY_RUN=false
POLL_INTERVAL_SECONDS=300
CORS_ORIGINS=*
TEMP_DIR=/tmp/bpo-ops
